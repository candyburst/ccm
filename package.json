{
  "name": "ccm-workspace",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "tui": "node packages/tui/bin/ccm.js",
    "app": "npm run dev --workspace=packages/app",
    "app:build": "npm run build --workspace=packages/app",
    "app:portable": "npm run build:portable --workspace=packages/app",
    "lint": "eslint packages/ --max-warnings 0",
    "lint:fix": "eslint packages/ --fix",
    "format": "prettier --write packages/",
    "format:check": "prettier --check packages/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "vitest": "^1.3.0"
  },
  "version": "1.0.0"
}
