{
  "name": "@ccm/app",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 --timeout 60000 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "build:mac": "vite build && electron-builder --mac",
    "build:win": "vite build && electron-builder --win",
    "build:linux": "vite build && electron-builder --linux",
    "build:portable": "vite build && electron-builder --mac zip --win portable --linux AppImage"
  },
  "dependencies": {
    "@ccm/core": "1.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "electron-updater": "6.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.2.1",
    "concurrently": "9.2.1",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0",
    "vite": "5.2.11",
    "wait-on": "7.2.0"
  },
  "build": {
    "appId": "com.ccm.app",
    "productName": "CCM",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../../packages/core",
        "to": "core",
        "filter": [
          "**/*",
          "!node_modules"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "candyburst",
      "repo": "ccm"
    },
    "releaseInfo": {
      "releaseNotes": "See CHANGELOG.md for details"
    }
  },
  "description": "CCM desktop app \u2014 multi-account Claude Code manager",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "electron",
    "account-manager"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
